# Copy this to ".env" and adjust if needed:  cp .env.example .env
#
# This local setup binds the scraper to 127.0.0.1 only, so NO API key is required.
# (The scraper image has no built-in authentication — localhost binding is the boundary.)

SCRAPER_BASE_URL=http://localhost:8080

# Only needed if you later expose the scraper beyond localhost behind an auth proxy
# (e.g. Caddy/nginx that checks an X-API-Key header). Leave blank for local use.
SCRAPER_API_KEY=
